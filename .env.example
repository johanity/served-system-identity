# Credentials are needed ONLY to re-run generation/grading.
# Re-deriving the paper's numbers from the released *.jsonl needs NO keys (pure recompute).
# Copy to `.env` and fill in. NEVER commit the real .env.
OPENROUTER_API_KEY=sk-or-v1-REPLACE_ME
GEMINI_API_KEY=REPLACE_ME            # Google AI Studio (generativelanguage) key
GOOGLE_CRED=/path/to/vertex-service-account.json   # Vertex AI service-account JSON
